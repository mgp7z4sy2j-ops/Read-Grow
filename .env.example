# Database — Neon PostgreSQL (required for production; optional locally — falls back to JSON files)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# AI recommendations (optional — local keyword matching used when unset)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Books price lookup (optional — works without key at low volume)
GOOGLE_BOOKS_API_KEY=

# Local dev server port
PORT=3000
